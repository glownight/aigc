NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=debug

# 允许的前端来源。多个域名用英文逗号分隔；设置 * 表示允许全部（不推荐生产使用）
# 示例：CORS_ORIGINS=http://localhost:5173,http://localhost:5177
CORS_ORIGINS=http://localhost:5173

# 每个 IP 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# 反向代理到上游模型服务
UPSTREAM_URL=https://tbnx.plus7.plus/v1/chat/completions
UPSTREAM_API_KEY=replace-with-your-server-side-key
DEFAULT_MODEL=deepseek-chat
REQUEST_TIMEOUT_MS=90000

# 请求体控制
MAX_MESSAGES=50
MAX_CONTENT_CHARS=12000

# 可选：给前端->后端增加一层简单 token 校验
# INTERNAL_API_TOKEN=
